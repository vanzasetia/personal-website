{% if page.url == "/" %}
  {% set url = site.url %}
  {% set pageTitle = site.title %}
{% elif capsule %}
  {% set pageTitle = "Vitamin L3: Capsule #" + title + " - Vanza Setia" %}
{% else %}
  {% set url = site.url + page.url %}
  {% set pageTitle = title + " - Vanza Setia" %}
{% endif %}
{% if socialPromo  %}
  {% set socialPromo = socialPromo %}
  {% set alt = alt %}
  {% else %}
  {% set socialPromo = "/images/social-share.png" %}
  {% set alt = "Go again. Help new web developers never surrender without drama. I am showing you how I think and do things. By Vanza Setia." %}
{% endif %}

<!DOCTYPE html>
<html lang="en">
  {% include "head.njk" %}
  <body>
    {{ content | safe }}
    {% include "svg.njk" %}
  </body>
</html>
