{
  "name": "root",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "eleventy",
    "start": "eleventy --serve --quiet --incremental",
    "debug": "set DEBUG=Eleventy* & eleventy",
    "clean": "rimraf _site",
    "check-links": "check-html-links _site",
    "validate-html": "html-validate ./_site/**/*.html",
    "format": "prettier --write .",
    "prepare": "husky",
    "lint-markdown": "markdownlint-cli2 \"**/*.md\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-navigation": "^1.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "check-html-links": "^0.2.4",
    "eleventy-auto-cache-buster": "^0.9.2",
    "html-minifier": "^4.0.0",
    "html-validate": "^11.5.3",
    "husky": "^9.0.11",
    "lightningcss": "^1.30.2",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-kbd": "^3.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdownlint": "^0.41.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "reading-time": "^1.5.0",
    "rimraf": "^6.0.1",
    "title": "^4.0.1"
  }
}
